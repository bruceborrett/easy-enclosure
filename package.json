{
  "name": "easy-enclosure",
  "version": "0.1.103",
  "private": true,
  "homepage": "https://bruceborrett.github.io/easy-enclosure/",
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d angular-app/dist/angular-app/browser",
    "ng:sync-version": "node -e \"const fs=require('node:fs');const v=process.env.npm_package_version||'dev';fs.writeFileSync('angular-app/src/app/app-version.ts', \\\"export const APP_VERSION = '\\\"+v+\\\"';\\\\n\\\");\"",
    "ng:dev": "npm run ng:sync-version && npm --prefix angular-app run start",
    "ng:build": "npm run ng:sync-version && npm --prefix angular-app run build",
    "ng:build:ghpages": "npm run ng:sync-version && npm --prefix angular-app run build",
    "ng:test": "npm --prefix angular-app run test --",
    "dev": "npm run ng:dev",
    "start": "npm run ng:dev",
    "build": "npm run ng:build",
    "prepare": "husky",
    "bump:version": "npm version patch --no-git-tag-version",
    "test": "npm run ng:test -- --watch=false --browsers=ChromeHeadless",
    "test:watch": "npm run ng:test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "gh-pages": "^5.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2"
  }
}
